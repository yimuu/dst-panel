{
  "name": "web-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build-only": "vite build",
    "build": "npm run type-check && npm run build-only",
    "type-check": "tsc -b",
